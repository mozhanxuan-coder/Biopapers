PUBMED_API_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PUBMED_DB=pubmed
PUBMED_EMAIL=mozhanxuan@gmail.com     # 替换为你的邮箱
PUBMED_API_KEY=c6804806c3a7192d740f17508c4b901a2207       # 替换为从 NCBI 获取的 Key（如果没有，可以暂时留空）
UNPAYWALL_EMAIL=mozhanxuan@gmail.com  # 替换为真实邮箱（Unpaywall 官方要求，用于联系超量请求的开发者）
PUBMED_TOOL=BioPapersCrawler

# Crawler Configuration
MAX_RETRIES=3
RETRY_DELAY=2
REQUEST_INTERVAL_MIN=1.0
REQUEST_INTERVAL_MAX=3.0
BATCH_SIZE=100

# Output Configuration
OUTPUT_DIR=data
LOG_DIR=logs
PROXY_ENABLED=False

